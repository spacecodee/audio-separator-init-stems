# Copy this file to .env and adjust values as needed.
# Common defaults used by endpoint scripts
DEFAULT_BASE=http://localhost:8000
DEFAULT_AUDIO=/teamspace/studios/this_studio/audio/Audio03.wav
DEFAULT_OUTPUT_FORMAT=wav
DEFAULT_POLL_SECONDS=5

# Output targets for static download scripts
DOCS_OUT=./docs.html
MODELS_EXPLORER_OUT=./models-explorer.html
MODELS_EXPLORER_HTML_OUT=./models-explorer.alias.html
MODELS_EXPLORER_CSS_OUT=./models-explorer.css
MODELS_EXPLORER_JS_OUT=./models-explorer.js
MODELS_JSON_OUT=./models.json
OPENAPI_JSON_OUT=./openapi.json
DOWNLOAD_OUT_DIR=.

# /separate
SEPARATE_AUDIO=/teamspace/studios/this_studio/audio/Audio04.wav
SEPARATE_MODEL=mel_roformer

# /separate/pipeline
SEPARATE_PIPELINE_AUDIO=/teamspace/studios/this_studio/audio/Audio03.wav
PIPELINE_STEP1_MODEL=bs_roformer
PIPELINE_STEP2_MODEL=mel_karaoke_gabox
PIPELINE_STEP3_MODEL=dereverb_echo

# /separate/guitar/pipeline
SEPARATE_GUITAR_AUDIO=/teamspace/studios/this_studio/audio/Audio04.wav
GUITAR_SPLIT_MODEL=htdemucs_6s
GUITAR_DEREVERB_MODEL=dereverb_mel

# /separate/vocals/reconstruct
VOCALS_RECONSTRUCT_AUDIO=/teamspace/studios/this_studio/audio/Audio03.wav
VOCALS_RECONSTRUCT_EXTRACT_MODEL=mel_roformer
VOCALS_RECONSTRUCT_MODEL=vocals_resurrection

# /separate/vocals/male-female
VOCALS_MALE_FEMALE_AUDIO=/teamspace/studios/this_studio/audio/Audio03.wav
VOCALS_MALE_FEMALE_EXTRACT_MODEL=mel_roformer
VOCALS_MALE_FEMALE_SPLIT_MODEL=chorus_male_female

# /effects/*
EFFECTS_AUDIO=/teamspace/studios/this_studio/audio/Audio03.wav
EFFECTS_DEREVERB_MODEL=dereverb_mel
EFFECTS_DEECHO_MODEL=deecho_normal
EFFECTS_COMBINED_MODEL=dereverb_echo
EFFECTS_FALLBACK_SEQUENTIAL=true
EFFECTS_FALLBACK_DEREVERB_MODEL=dereverb_mel
EFFECTS_FALLBACK_DEECHO_MODEL=deecho_normal

# Root scripts
APP_AUDIO_FILE=/teamspace/studios/this_studio/audio/Audio03.wav
APP_PIPELINE_STEP1_MODEL=bs_roformer
APP_PIPELINE_STEP2_MODEL=mel_karaoke_gabox
APP_PIPELINE_STEP3_MODEL=dereverb_echo
APP_OUTPUT_FORMAT=wav
APP_POLL_SECONDS=5

SERVICE_NAME=stem-separator
BEST_PIPELINE_DEREVERB_MODEL=dereverb_mel_band_roformer_anvuew_sdr_19.1729.ckpt
BEST_PIPELINE_KARAOKE_SPLIT_MODEL=mel_band_roformer_karaoke_aufr33_viperx_sdr_10.1956.ckpt
MODELS_EXPLORER_PORT=8088
EXPORT_MODELS_SERVICE_NAME=stem-separator
EXPORT_MODELS_OUTPUT_FILE=./models.json
